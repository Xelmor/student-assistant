APP_ENV=development
SECRET_KEY=replace_with_a_unique_random_string_at_least_32_chars_long
COOKIE_SECURE=false
DATABASE_URL=sqlite:///./student_assistant.db
HOST=0.0.0.0
PORT=8000
RELOAD=false
APP_TIMEZONE=Europe/Moscow

ALLOW_LOCAL_PRIVATE_DATA=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Student Assistant
SMTP_STARTTLS=true
SMTP_SSL=false
PASSWORD_RESET_TOKEN_TTL_SECONDS=3600
TELEGRAM_BOT_API_TOKEN=replace_with_internal_shared_token
TELEGRAM_LINK_CODE_TTL_MINUTES=15

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_API_BASE_URL=http://localhost:8000
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_WEBHOOK_BASE_URL=
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_HOST=0.0.0.0
TELEGRAM_BOT_PORT=8081
TELEGRAM_BOT_LOG_LEVEL=INFO

# Production example:
# APP_ENV=production
# COOKIE_SECURE=true
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
